# application
NODE_ENV=development
PORT=3000

# database
DATABASE_URL=postgresql://pg_user:pg_password@pg_host/pg_database

# JWT — generate random secrets (min 32 chars). ACCESS and REFRESH must differ.
ACCESS_TOKEN_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET_MIN_32_CHARS
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=CHANGE_ME_GENERATE_A_DIFFERENT_SECRET_MIN_32_CHARS
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=https://api.example.com

# logging
LOG_LEVEL=info
LOG_TO_FILE=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080

# rate limiting
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_GENERAL_MAX=100
